    "id": "twinned_spell_metamagic_2014",
    "name": "Twinned Spell",
    "source": "PHB 2014",
    "type": "metamagic",
    "description": "When you cast a spell that targets only one creature and doesn't have a range of self, you can spend a number of sorcery points equal to the spell's level to target a second creature in range with the same spell (1 sorcery point if the spell is a cantrip). To be eligible for Twinned Spell, a spell must be incapable of targeting more than one creature at the spell's current level.",
    "modifiers": {
      "resourceCosts": [
        {
          "resource": "sorcery_points",
          "amount": {
            "ifCantrip": 1,
            "otherwiseEqualsSpellLevel": true
          }
        }
      ],
      "metamagic": {
        "kind": "twinned_spell",
        "requiresSingleTargetSpell": true,
        "cannotTargetSelfRange": true,
        "addsSecondTargetInRange": true,
        "requiresSpellIncapableOfTargetingMoreThanOneCreatureAtCurrentLevel": true
      },
      "resourceCostsV2": [
        {
          "resource": "sorcery_points",
          "cost": {
            "ifCantrip": 1,
            "otherwiseEqualsSpellLevel": true
          }
        }
      ],
      "metamagicV2": {
        "kind": "twinned_spell",
        "requiresSingleTargetSpell": true,
