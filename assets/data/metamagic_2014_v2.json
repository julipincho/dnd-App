  {
    "id": "careful_spell_metamagic_2014",
    "name": "Careful Spell",
    "source": "PHB 2014",
    "type": "metamagic",
    "description": "When you cast a spell that forces other creatures to make a saving throw, you can protect some of those creatures from the spell's full force. To do so, you spend 1 sorcery point and choose a number of those creatures up to your Charisma modifier (minimum of one creature). A chosen creature automatically succeeds on its saving throw against the spell.",
    "modifiers": {
      "resourceCosts": [
        {
          "resource": "sorcery_points",
          "amount": 1
        }
      ],
      "metamagic": {
        "kind": "careful_spell",
        "requiresSpellSavingThrow": true,
        "protectChosenCreatures": true,
        "protectedCreatureCount": {
          "scalesWith": "charisma_modifier",
          "minimum": 1
        },
        "protectedCreaturesAutoSucceedSave": true
      },
      "resourceCostsV2": [
        {
          "resource": "sorcery_points",
          "cost": 1
        }
      ],
      "metamagicV2": {
        "kind": "careful_spell",
        "requiresSpellSavingThrow": true,
        "protectChosenCreatures": true,
        "protectedCreatureCount": {
