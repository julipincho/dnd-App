  {
    "id": "superior_technique_fighting_style_tce",
    "name": "Superior Technique",
    "source": "TCE",
    "type": "fighting_style",
    "description": "You learn one maneuver of your choice from among those available to the Battle Master archetype in the fighter class. If a maneuver you use requires your target to make a saving throw to resist the maneuver's effects, the saving throw DC equals 8 + your proficiency bonus + your Strength or Dexterity modifier (your choice). You gain one superiority die, which is a d6. This die is used to fuel your maneuver. A superiority die is expended when you use it. You regain your expended superiority dice when you finish a short or long rest.",
    "modifiers": {
      "resourcesGranted": [
        {
          "resource": "superiority_die",
          "amount": 1,
          "dieSize": 6,
          "recovery": "short_or_long_rest"
        }
      ],
      "grantsChoice": {
        "kind": "battle_master_maneuver",
        "count": 1
      },
      "specialRules": {
        "maneuverSaveDcFormula": "8 + proficiency_bonus + chosen(strength_modifier,dexterity_modifier)",
        "maneuverSaveDcFormulaV2": {
          "base": 8,
          "addProficiencyBonus": true,
          "addChosenAbilityModifier": [
            "strength",
            "dexterity"
          ]
        }
      }
    },
    "normalizedBy": "normalize_class_option_modifiers_v2.py",
    "normalizationVersion": 2
  },
  {
    "id": "unarmed_fighting_fighting_style_tce",
    "name": "Unarmed Fighting",
    "source": "TCE",
    "type": "fighting_style",
    "description": "Your unarmed strikes can deal bludgeoning damage equal to 1d6 + your Strength modifier on a hit. If you aren't wielding any weapons or a shield when you make the attack roll, the d6 becomes a d8. At the start of each of your turns, you can deal 1d4 bludgeoning damage to one creature grappled by you.",
    "modifiers": {
      "unarmedStrike": {
        "damage": {
          "default": "1d6 + strength_modifier",
          "ifNoWeaponsOrShield": "1d8 + strength_modifier"
        }
      },
      "startOfTurnEffects": [
        {
          "effect": "deal_damage_to_grappled_creature",
          "damage": "1d4 bludgeoning",
          "targetConstraint": "one_creature_grappled_by_you"
        }
      ]
    },
    "normalizedBy": "normalize_class_option_modifiers_v2.py",
    "normalizationVersion": 2
  },
  {
    "id": "blessed_warrior_fighting_style_tce",
    "name": "Blessed Warrior",
    "source": "TCE",
    "type": "fighting_style",
    "description": "You learn two cantrips of your choice from the cleric spell list. They count as paladin spells for you, and Charisma is your spellcasting ability for them. Whenever you gain a level in a class that grants this feature, you can replace one of these cantrips with another cantrip from the cleric spell list.",
    "modifiers": {
      "grantsChoice": {
        "kind": "cleric_cantrip",
        "count": 2
      },
      "specialRules": {
        "countAsPaladinSpells": true,
        "spellcastingAbility": "charisma",
        "canReplaceOnLevelGrantingFeature": true
      }
    },
    "normalizedBy": "normalize_class_option_modifiers_v2.py",
    "normalizationVersion": 2
  },
